@model YemekSepetiWeb.Models.Restoranlar

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

@if (ViewBag.Hata != null)
{
    <div class="alert alert-danger">
        <strong>⚠️ İşlem Engellendi:</strong> @ViewBag.Hata
    </div>
}
<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Restoranlar</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.RestoranAdi)
        </dt>
