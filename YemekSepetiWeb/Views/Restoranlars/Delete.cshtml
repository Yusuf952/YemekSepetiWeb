            @Html.DisplayFor(model => model.RestoranAdi)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Kategori)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Kategori)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MinTutar)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MinTutar)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Puan)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Puan)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ResimYolu)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ResimYolu)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="RestoranId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>