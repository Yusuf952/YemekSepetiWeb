@model IEnumerable<YemekSepetiWeb.Models.Urunler>

@{
    ViewData["Title"] = "Menü";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger">🍽️ @ViewBag.RestoranAdi - Menü</h2>

        <div>
            <a asp-action="Index" class="btn btn-outline-secondary mr-2">⬅️ Restoranlara Dön</a>
            <a asp-action="Sepet" class="btn btn-warning text-white">
                🛒 Sepeti Gör
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            Bu restoranın henüz menüsü eklenmemiş.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title font-weight-bold">@item.UrunAdi</h5>
                                <p class="card-text text-muted">@item.Aciklama</p>
                                <h4 class="text-success">@item.Fiyat TL</h4>
                            </div>

                            <a asp-action="SepeteEkle" asp-route-id="@item.UrunId" class="btn btn-danger btn-sm px-4 py-2">
                                + Sepete Ekle
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>