@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Yemeksepeti - Giriş & Kayıt</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
        }

        .divider {
            border-right: 1px solid #ddd;
        }

        /* HATA ÇÖZÜMÜ: @@media kullanımı korundu */
        @@media (max-width: 768px) {
            .divider {
                border-right: none;
                border-bottom: 1px solid #ddd;
                padding-bottom: 20px;
                margin-bottom: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container mt-4">
        <div class="text-center mb-4">
            <h1 class="display-4 text-danger font-weight-bold">Yemeksepeti</h1>
            <p class="lead">Giriş Yap veya Hemen Aramıza Katıl</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-11">
                <div class="card shadow-lg">
                    <div class="card-body p-4">
                        <div class="row">

                            <div class="col-md-4 divider">
                                <h4 class="text-primary mb-3">👨‍💻 Yönetici</h4>
                                @if (ViewBag.Hata != null)
                                {
                                    <div class="alert alert-danger">@ViewBag.Hata</div>
                                }
                                <form asp-action="AdminLogin" method="post">
                                    <div class="form-group">
                                        <input type="text" name="username" class="form-control" placeholder="Kullanıcı Adı" required />
                                    </div>
                                    <div class="form-group">
                                        <input type="password" name="password" class="form-control" placeholder="Şifre" required />
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-block">Giriş Yap</button>
                                </form>
                            </div>

                            <div class="col-md-4 divider">
                                <h4 class="text-success mb-3">🍔 Kayıtlı Müşteri</h4>
                                <p class="small text-muted">Zaten üyeysen ismini seç ve şifreni gir:</p>

                                @if (ViewBag.MusteriHata != null)
                                {
                                    <div class="alert alert-danger">@ViewBag.MusteriHata</div>
                                }

                                <form asp-action="MusteriLogin" method="post">
                                    <div class="form-group">
                                        <select name="kullaniciId" class="form-control" asp-items="ViewBag.Kullanicilar" required>
                                            <option value="">-- İsmini Seç --</option>
                                        </select>
                                    </div>

                                    <div class="form-group">
                                        <input type="password" name="sifre" class="form-control" placeholder="Şifreniz" required />
                                    </div>
                                    <button type="submit" class="btn btn-success btn-block">Giriş Yap</button>
                                </form>
                            </div>

                            <div class="col-md-4">
                                <h4 class="text-warning mb-3">📝 Yeni Üye Ol</h4>
                                <p class="small text-muted">Bilgilerini gir, şifreni belirle:</p>
                                <form asp-action="HizliKayit" method="post">
                                    <div class="form-group">
                                        <input type="text" name="adSoyad" class="form-control" placeholder="Adın Soyadın" required />
                                    </div>

                                    <div class="form-group">
                                        <input type="email" name="email" class="form-control" placeholder="E-posta Adresi" required />
                                    </div>

                                    <div class="form-group">
                                        <input type="password" name="sifre" class="form-control" placeholder="Şifre Belirle" required />
                                    </div>
                                    <div class="form-group">
                                        <input type="text" name="telefon" class="form-control" placeholder="Telefon (İsteğe bağlı)" />
                                    </div>
                                    <div class="form-group">
                                        <textarea name="adres" class="form-control" placeholder="Adres (İsteğe bağlı)" rows="2"></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-warning btn-block text-white font-weight-bold">Kaydet ve Başla 🚀</button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>